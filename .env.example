# PROP Server configuration
# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────
# Postgres connection URL for your self-hosted prop.* schema.
# Supports any standard Postgres URL:
#   Neon:       postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Supabase:   postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Hyperdrive: postgresql://user:pass@<id>.hyperdrive.io:5432/db
#   Local:      postgresql://localhost:5432/mydb
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on (default: 3001)
PORT=3001

# ── Optional ─────────────────────────────────────────────────
# OpenAI API key — required only if using the built-in Ask Widget handler.
# Remove if you implement your own action handlers.
OPENAI_API_KEY=sk-...

# CORS origin — restrict which domains can call this server.
# Defaults to * (open). Set to your app domain in production.
CORS_ORIGIN=*

# Private PROP server secret key — authorizes this server to call Headlo's managed
# services (auth, billing) and lets Headlo sync component routing from your DB.
# Generate at: headlo.com/dashboard/settings → PROP Server Secret Key
# Never expose in browser code or commit to version control.
PRIVATE_PROP_SERVER_KEY=hlk_...

# URL of this server — used by Headlo to route component requests to your instance.
# Set to your public server URL in production.
PRIVATE_PROP_SERVER_URL=https://prop.acme.com

# ── External private PROP servers ────────────────────────────
# Connect to other private prop servers to use their components.
# Each entry is a URL + publishable key pair (get the key from the other server's owner).
# Slugs are resolved in order: this server first, then external servers in sequence.
#
# EXTERNAL_PROP_SERVER_1_URL=https://prop.partner.com
# EXTERNAL_PROP_SERVER_1_KEY=pk_live_...
#
# EXTERNAL_PROP_SERVER_2_URL=https://prop.vendor.com
# EXTERNAL_PROP_SERVER_2_KEY=pk_live_...

# ── PROP Server Publishable Key (browser-safe) ───────────────
# Identifies your account for billing on browser/embed requests.
# Safe to include in client-side code (VITE_HEADLO_PROP_SERVER_PUBLISHABLE_KEY).
# Generate at: headlo.com/dashboard/settings → PROP Server Keys
# Set allowed origins on the key to restrict which domains can use it.
# VITE_HEADLO_PROP_SERVER_PUBLISHABLE_KEY=pk_live_...
