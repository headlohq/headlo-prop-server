# PROP Server configuration
# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────
# Postgres connection URL for your self-hosted prop.* schema.
# Supports any standard Postgres URL:
#   Neon:       postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Supabase:   postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Hyperdrive: postgresql://user:pass@<id>.hyperdrive.io:5432/db
#   Local:      postgresql://localhost:5432/mydb
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on (default: 3001)
PORT=3001

# ── Optional ─────────────────────────────────────────────────
# OpenAI API key — required only if using the built-in Ask Widget handler.
# Remove if you implement your own action handlers.
OPENAI_API_KEY=sk-...

# CORS origin — restrict which domains can call this server.
# Defaults to * (open). Set to your app domain in production.
CORS_ORIGIN=*

# Headlo API key — if you want Headlo to sync routing from this server.
# Get from your Headlo dashboard under Settings → Self-host.
HEADLO_PROP_SERVER_KEY=hlk_...
