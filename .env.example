# PROP Server configuration
# Copy to .env and fill in your values

# ── Required ────────────────────────────────────────────────
# Postgres connection URL for your self-hosted prop.* schema.
# Supports any standard Postgres URL:
#   Neon:       postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
#   Supabase:   postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#   Hyperdrive: postgresql://user:pass@<id>.hyperdrive.io:5432/db
#   Local:      postgresql://localhost:5432/mydb
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the server listens on (default: 3001)
PORT=3001

# ── Keys ────────────────────────────────────────────────────
# Keys are stored per-agency in prop_server.api_key (no env var needed here).
#
#   publishable_key (X-Headlo-Prop-Publishable-Key) — browser-safe, validated against allowed_origins
#   secret_key      (X-Headlo-Prop-Secret)          — server-side only, bypasses origin check
#
# Generate values:  openssl rand -hex 20 | awk '{print "pk_live_"$1}'  # publishable_key
#                   openssl rand -hex 32 | awk '{print "sk_"$1}'       # secret_key
# Insert into DB:   INSERT INTO prop_server.api_key (agency_id, publishable_key, secret_key, ...) VALUES (...);

# ── Optional ─────────────────────────────────────────────────
# CORS origin — restrict which domains can call this server.
# Defaults to * (open). Set to your app domain in production.
CORS_ORIGIN=*

# URL of this server — used by Headlo to route component requests to your instance.
PROP_SERVER_URL=https://prop.acme.com
